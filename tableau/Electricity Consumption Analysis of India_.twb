  <dashboards>
    <dashboard name='Electricity Consumption Analysis Story' type='storyboard'>
      <style />
      <size maxheight='964' maxwidth='1016' minheight='964' minwidth='1016' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='4772' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone h='10477' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='5602' />
            <zone h='83091' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='16079'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Electricity Consumption Trend (2019–2020)&#10;&#10;This visualization shows the monthly electricity consumption trend across India. &#10;The data highlights seasonal demand fluctuations and changes in electricity usage patterns over the two-year period.' captured-sheet='Monthly Electricity Consumption Trend' id='1' />
                  <story-point caption='Regional Electricity Demand&#10;&#10;This visualization compares electricity consumption across different regions of India. &#10;The Northern, Southern, and Western regions show higher electricity demand compared to Eastern and North-Eastern regions.' captured-sheet='Electricity Consumption by Region' id='2' />
                  <story-point caption='State-wise Electricity Distribution&#10;&#10;The map visualization displays electricity consumption across Indian states. &#10;States with higher electricity usage appear more prominently, helping identify geographical demand patterns.' captured-sheet='State-wise Electricity Consumption Map' id='3'>
                    <capturedDeltas>
                      <worksheet name='State-wise Electricity Consumption Map'>
